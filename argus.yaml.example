# AthenaBeaver Configuration
# Copy this to argus.yaml (or ~/.argus.yaml) and customize.

aws:
  region: us-east-1
  profile: null  # Use null for default credential chain, or specify a profile name

workgroups:
  output_locations:
    # Map workgroup name -> S3 URI for query results
    # "analytics_123456_prod": "s3://my-athena-results/123456/prod/"
    # "analytics_123456_dev": "s3://my-athena-results/123456/dev/"

defaults:
  output_location: "s3://my-athena-results/default/"
  max_results: 100
  query_timeout_seconds: 300

# locked_settings: List of UI setting keys that users cannot change.
# Valid values: theme, sqlAutocomplete, sqlDiagnostics, showHistoryDefault,
#               showInformationSchema, formatStyle, autoLimit
# locked_settings:
#   - autoLimit
#   - formatStyle
