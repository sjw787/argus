#!/bin/bash
# Pre-push git hook: runs test coverage and enforces thresholds.
#
# Behaviour:
#   - Always runs the full test suite with coverage before any push.
#   - Blocks the push if tests fail.
#   - Ratchet: coverage must never drop below the last recorded value (.coverage-baseline).
#     This inches coverage toward 87% with every push.
#   - Tracks whether the 87% target has ever been achieved (.coverage-threshold-met).
#   - Before 87% is reached : push blocked if coverage regressed; warns with progress otherwise.
#   - After 87% is reached   : enforces an 85% floor — push blocked if coverage drops below.
#
# Install: run scripts/install-hooks.sh from the repo root.

set -euo pipefail

COVERAGE_TARGET=87
COVERAGE_FLOOR=85
ROOT="$(git rev-parse --show-toplevel)"
THRESHOLD_MET_FILE="$ROOT/.coverage-threshold-met"
BASELINE_FILE="$ROOT/.coverage-baseline"

cd "$ROOT"

echo ""
echo "🔍 Running test suite with coverage..."

# Activate venv if present
if [ -f "$ROOT/venv/bin/activate" ]; then
  source "$ROOT/venv/bin/activate"
fi

# Run tests and capture output
COVERAGE_OUTPUT=$(PYTHONPATH=src python -m pytest tests/ -q \
  --cov=argus \
  --cov-report=term-missing \
  --tb=short 2>&1) || {
  echo ""
  echo "$COVERAGE_OUTPUT"
  echo ""
  echo "❌  Tests failed. Push blocked."
  exit 1
}

echo "$COVERAGE_OUTPUT" | tail -20

# Extract total coverage percentage (e.g. "44%" → 44)
COVERAGE_PCT=$(echo "$COVERAGE_OUTPUT" | grep "^TOTAL" | awk '{print $4}' | tr -d '%')

if [ -z "$COVERAGE_PCT" ]; then
  echo "⚠️  Could not determine coverage percentage — allowing push."
  exit 0
fi

echo ""
echo "📊 Coverage: ${COVERAGE_PCT}%"

# --- Ratchet: coverage must not regress below the last recorded baseline ---
if [ -f "$BASELINE_FILE" ]; then
  BASELINE=$(cat "$BASELINE_FILE")
  if python3 -c "import sys; sys.exit(0 if float('$COVERAGE_PCT') >= float('$BASELINE') else 1)"; then
    echo "✅ Coverage held or improved (was ${BASELINE}%, now ${COVERAGE_PCT}%)"
  else
    echo ""
    echo "❌  Coverage regression: was ${BASELINE}%, now ${COVERAGE_PCT}%."
    echo "    Coverage must not decrease. Add tests to restore or exceed ${BASELINE}% before pushing."
    exit 1
  fi
fi

# --- Check if the 87% target has now been met for the first time ---
if python3 -c "import sys; sys.exit(0 if float('$COVERAGE_PCT') >= $COVERAGE_TARGET else 1)"; then
  if [ ! -f "$THRESHOLD_MET_FILE" ]; then
    echo "🎉 Coverage target of ${COVERAGE_TARGET}% reached! Floor of ${COVERAGE_FLOOR}% is now enforced."
    echo "$COVERAGE_TARGET" > "$THRESHOLD_MET_FILE"
    git add "$THRESHOLD_MET_FILE" 2>/dev/null || true
  fi
fi

# --- Update the baseline to the current percentage ---
echo "$COVERAGE_PCT" > "$BASELINE_FILE"
git add "$BASELINE_FILE" 2>/dev/null || true

# --- Enforce 85% floor once the 87% target has been achieved ---
if [ -f "$THRESHOLD_MET_FILE" ]; then
  if python3 -c "import sys; sys.exit(0 if float('$COVERAGE_PCT') >= $COVERAGE_FLOOR else 1)"; then
    echo "✅ Coverage ${COVERAGE_PCT}% meets the ${COVERAGE_FLOOR}% floor. Push allowed."
  else
    echo ""
    echo "❌  Coverage ${COVERAGE_PCT}% is below the ${COVERAGE_FLOOR}% floor."
    echo "    The ${COVERAGE_TARGET}% target was previously achieved, so ${COVERAGE_FLOOR}% is now enforced."
    echo "    Add or fix tests to bring coverage back above ${COVERAGE_FLOOR}% before pushing."
    exit 1
  fi
else
  # Target not yet reached — report progress
  REMAINING=$(python3 -c "print(round($COVERAGE_TARGET - float('$COVERAGE_PCT'), 1))")
  echo "⚠️  ${REMAINING}pp to go until the ${COVERAGE_TARGET}% target."
  echo "   Please add tests to keep improving coverage."
fi

exit 0
